# ============================================================
# Agentic AI: From Zero to Production
# Environment Variables Template
#
# Instructions:
# 1. Copy this file to .env in the root of the repo
# 2. Fill in your values
# 3. Never commit .env to GitHub
# ============================================================

# ── REQUIRED ─────────────────────────────────────────────────

# OpenAI API key
# Get from: platform.openai.com → API Keys
OPENAI_API_KEY=

# ── OPTIONAL BUT RECOMMENDED ─────────────────────────────────

# Anthropic API key (for Claude examples)
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# LangSmith tracing (highly recommended for observability)
# Get from: smith.langchain.com → Settings → API Keys
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=agentic-ai-zero-to-production
