# ==============================================================================
# Agentic AI - Zero to Production Course - Local Environment Settings
# Copy this file to '.env' and fill in your actual credentials.
# DO NOT COMMIT THE '.env' FILE TO VERSION CONTROL!
# ==============================================================================

# ------------------------------------------------------------------------------
# Core Language Model Provider Configuration
# ------------------------------------------------------------------------------
# We primarily use OpenAI for foundational exercises.
OPENAI_API_KEY=your_openai_api_key_here

# (Optional) Anthropic, in case you run multi-model router scenarios.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Fallback configurations (if using mock endpoints)
MOCK_LLM_MODE=false
DEFAULT_MODEL_NAME=gpt-4o-mini
HEAVY_MODEL_NAME=gpt-4o

# ------------------------------------------------------------------------------
# Vector Database & Retrieval Configurations (Module 04 / RAG)
# ------------------------------------------------------------------------------
CHROMA_DB_PATH=./chromadb
EMBEDDING_MODEL=text-embedding-3-small

# ------------------------------------------------------------------------------
# Enterprise & Safety Configuration (Module 09)
# ------------------------------------------------------------------------------
GUARDRAILS_MAX_STEPS=10
GUARDRAILS_MAX_COST_USD=2.00
SAFETY_AUDIT_LOG_PATH=./safety_audit.log

# ------------------------------------------------------------------------------
# Observability & Tracing (Module 08)
# ------------------------------------------------------------------------------
# We support OpenTelemetry (Phoenix / LangSmith / Langfuse hooks)
LITE_OBSERVABILITY_MODE=true

# Phoenix OpenTelemetry Endpoint
PHOENIX_COLLECTOR_HTTP_ENDPOINT=http://localhost:6006

# LangSmith (Optional Integration)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=agentic-ai-zero-to-production

# ------------------------------------------------------------------------------
# Course Sandbox Settings
# ------------------------------------------------------------------------------
RUN_MODE=development
LOG_LEVEL=INFO
